# Подключение к PostgreSQL. Railway подставляет автоматически.
DATABASE_URL=postgresql://finance_user:finance_password@localhost:5432/finance_tracker

# Разрешённые origins для CORS (через запятую). Добавить Vercel URL в продакшене.
CORS_ORIGINS=https://your-project.vercel.app

# Одноразовый флаг: пересоздать таблицы budget_items и budget_incomes.
# Выставить "1", перезапустить бэкенд, вернуть "0" (или убрать).
# RESET_BUDGET_SCHEMA=1
